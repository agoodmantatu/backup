            preview: a.summary, important: false, source: a.source,
          })))
        }
      } catch {
        // Supabase table empty/missing — keep static NEWS fallback
      }
    })()
  }, [])"""
c = c.replace(old, new)

# Replace all uses of NEWS (the filtered source) with `news`
c = c.replace("cat==='All' ? NEWS : NEWS.filter(n=>n.cat===cat)", "cat==='All' ? news : news.filter(n=>n.cat===cat)")

# Reward coins on expand (read an article)
c = c.replace(
    "setExpanded(",
    "rewardCurrentAffairsRead({amount:5}); setExpanded(",
    1
)

with open(path,'w') as f: f.write(c)
print("✅ CurrentAffairs.jsx — now fetches from Supabase 'current_affairs' table")
print("   (falls back to 8 seeded articles if table empty/missing)")
print("   +5 coins awarded when a student opens any article")

